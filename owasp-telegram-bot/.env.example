# ============================================================
# OWASP Secure Telegram Bot - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control!

# --- Telegram Bot Token (from @BotFather on Telegram) ---
BOT_TOKEN='your_telegram_bot_token_here'

# --- VirusTotal API Key (register free at virustotal.com) ---
VIRUSTOTAL_API_KEY='your_virustotal_api_key_here'

# --- Gemini API Key (from aistudio.google.com) ---
GEMINI_API_KEY='your_gemini_api_key_here'

# --- Web Server Settings ---
WEB_HOST=0.0.0.0
WEB_PORT=8000

# --- Rate Limiting (max requests per minute per user/IP) ---
# OWASP A04: Insecure Design - prevent brute-force/DoS
RATE_LIMIT=5

# --- Database file path ---
# Default uses SQLite in the 'data' directory
DATABASE_URL=sqlite+aiosqlite:///./data/scans.db

# --- Logging Level ---
LOG_LEVEL=INFO
